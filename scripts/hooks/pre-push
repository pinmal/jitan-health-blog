#!/bin/sh
# pre-push hook: 書籍↔Web齟齬チェック (Phase 5)
# CRITICAL があれば push をブロックする
# 参照: CSO/kindle-publishing/WRITING-CONSTITUTION.md
#
# 【復元方法】git clone 後に npm install を実行すると自動でインストールされる
# 手動復元: node scripts/install-hooks.js

echo "[pre-push] cross_site_check.py --scan-all 実行中..."
python "C:/Users/yotsu/Desktop/claudecode1/CSO/kindle-publishing/cross_site_check.py" --scan-all
RC=$?
if [ $RC -ne 0 ]; then
  echo ""
  echo "[pre-push] CRITICAL 検出 (exit=$RC) -> push を中止"
  echo "[pre-push] 本文を書籍(凍結正典)に合わせて修正してから再 push してください"
  echo "[pre-push] 緊急時バイパス: git push --no-verify"
  exit 1
fi
echo "[pre-push] OK: 書籍齟齬なし -> push を続行"
exit 0
