---
const UTM_ART = 'utm_source=kindle&utm_medium=ebook&utm_campaign=kindle-guide';
const TAG = 'jitankenko-22';

function articleUrl(slug: string) {
  return `/articles/${slug}/?${UTM_ART}`;
}
function amazonUrl(asin: string, num: string) {
  return `https://www.amazon.co.jp/dp/${asin}/?tag=${TAG}&utm_source=kindle&utm_medium=ebook&utm_campaign=${num}&utm_content=kindle-guide`;
}

const SECTIONS = [
  {
    id: 'time',
    label: '時短・食事管理',
    emoji: '🍱',
    alt: false,
    desc: '帰宅後の夕食準備・お弁当・食費節約など、毎日の食事をラクにするテーマの本です。',
    articles: [
      { slug: 'batch-cooking-weekend-solo-yuka-drama',     title: '週末バッチ調理で平日の食事を確保する｜3時間仕込みの実践',  badge: 'バッチ調理' },
      { slug: 'weekday-dinner-systemization',              title: '平日夕食の仕組み化 完全ガイド',                       badge: '仕組み化' },
      { slug: 'kenji-weekend-tsukurioki-drama',            title: '週末作り置き｜共働き父の正直レポート',               badge: '作り置き' },
      { slug: 'lunch-management-solo-living-psychiatrist', title: '一人暮らしの昼食管理｜午後の集中力を守る食事',       badge: '昼食管理' },
      { slug: 'solo-living-food-cost-drama',               title: '一人暮らし食費の節約｜宅食・自炊・コンビニを比較', badge: '食費節約' },
    ],
    books: [
      { num: 'book06', asin: 'B0GY1BZ91Y', title: '帰宅22時からでも続けられる一人暮らし時短メシ50品', desc: '仕事終わりでも10分以内で完結する献立50選。買い物からの逆算設計で「献立を考える」手間をゼロにする。', badge: '時短' },
      { num: 'book13', asin: 'B0GX32M6WX', title: '週末2時間で作り置き60選',                             desc: '日曜の2時間が平日5日間の夕食を解決する。冷蔵・冷凍保存ルールと使い回し献立60レシピ。',             badge: '作り置き' },
      { num: 'book19', asin: 'B0GYSSXVQL', title: 'コンビニ飯 罪悪感ゼロ！忙しい30代のリアルな食事管理術', desc: 'コンビニ食を「手抜き」ではなく「戦略」に変える。栄養バランスを保ちながらコストを抑える選び方。',    badge: 'コンビニ' },
      { num: 'book21', asin: 'B0H2RVPVMW', title: '自炊が続かない人の「70点ごはん」習慣ガイド',           desc: '完璧を求めるから続かない。70点で十分という考え方で、料理が苦手な人でも無理なく続く食習慣を作る。', badge: '習慣化' },
      { num: 'book27', asin: 'B0GX38LGCG', title: '一人暮らしの食費1万5千円生活',                        desc: '食費を削っても栄養を落とさない。買い物ルーティンと食材の使い切り術で月15,000円を実現する方法。',   badge: '節約' },
      { num: 'book72', asin: 'B0H64LQ6SN', title: '食費月1万円でも栄養バランスが取れる献立術',             desc: '月28,000円のコンビニ食費を月1万円に圧縮した食費設計記録。1日330円の予算で栄養バランスを崩さない買い物・献立システムを解説。',                              badge: '月1万円' },
      { num: 'book73', asin: 'B0H6HD6CWS', title: '夜ごはん×翌日弁当 一度の料理で二度おいしい作り方',      desc: '夕食を作りながら翌日の弁当も同時に完成させる「一石二鳥」設計術。帰宅後のキッチンに立つのは一度だけ——共働き・一人暮らしの調理時間を半分にする献立の考え方。',   badge: '弁当×夕飯' },
      { num: 'book75', asin: 'B0H6L2MB9P', title: 'ミールプレップ入門 週末2時間で平日の食事を全部準備する', desc: '週末の2時間で平日5日分の食事を完成させる「ミールプレップ」入門。調理順序・冷蔵冷凍の保存設計・飽きない味変テクを日本の一人暮らしに合わせて再設計した実践ガイド。', badge: 'ミールプレップ' },
      { num: 'book33', asin: 'B0H398RMYR', title: '冷凍保存マスター術 食材ロスゼロで食費を自動的に減らす', desc: '食材を腐らせる前に冷凍するだけで食費が下がる。食材別の正しい冷凍方法と解凍・調理テク。',           badge: '冷凍' },
      { num: 'book43', asin: 'B0H38YLS4V', title: 'スープジャー弁当50選 朝5分で作る職場ランチ',            desc: '朝5分のお湯を注ぐだけで昼に熱々スープが完成。節約・栄養・時短を一度に解決するスープジャー活用術。', badge: '弁当' },
      { num: 'book44', asin: 'B0H3DSNDP6', title: '電子レンジだけで作る週5の晩ごはん',                   desc: 'コンロを一切使わずレンジだけで作れる晩ごはん。洗い物も最小限で、平日の帰宅後30分を丸ごと取り戻す。', badge: 'レンジ' },
      { num: 'book45', asin: 'B0GX32M8RN', title: '在宅ワーカーの昼食ルーティン完全ガイド',               desc: '在宅勤務の昼食は「作りすぎ」か「食べなさすぎ」になりがち。午後の集中力を落とさない昼食設計を解説。', badge: '在宅' },
      { num: 'book267', asin: 'B0H7PH4JLQ', title: '週末3時間バッチ調理で5日間の食事を確保する本', desc: '週末土曜3時間の仕込みで月〜金5日分の夕食を確保するバッチ調理術。PMの工程設計思考を食事管理に応用し、帰宅後10分以内に食べられる状態を仕組みで作る実践ガイド。', badge: 'バッチ調理' },
    ],
    products: [
      { name: 'ガラス製保存容器セット', href: 'https://www.amazon.co.jp/s?k=ガラス保存容器+電子レンジ対応+密閉&tag=jitankenko-22', desc: 'バッチ調理の必需品。においが移りにくく電子レンジ・食洗機対応。700ml〜1000mlサイズを4〜5個そろえると一人暮らしの仕込み量にちょうどよい。', badge: '保存容器' },
      { name: '炊飯器（タイマー機能付き）', href: 'https://www.amazon.co.jp/s?k=炊飯器+タイマー+5合+マイコン&tag=jitankenko-22', desc: '前夜にセットして朝に炊き上がり。週に一度まとめて炊いて冷凍保存する「ご飯の仕込み」もバッチ調理の重要な一工程。', badge: '炊飯器' },
    ],
  },
  {
    id: 'takushoku',
    label: '宅食・サービス選び',
    emoji: '🏠',
    alt: true,
    desc: '宅食サービスを本音で比較。忙しい人がサービスを賢く選ぶための情報をまとめています。',
    articles: [
      { slug: 'sougou-takushoku-5sha-comparison-psychiatrist', title: '宅食おすすめ5社を徹底比較',             badge: '総合比較' },
      { slug: 'noshi-vs-mitsuboshi-vs-muscledeli',             title: 'ナッシュ・らでぃっしゅぼーや・マッスルデリ 比較', badge: '3社比較' },
      { slug: 'low-carb-delivery-comparison-psychiatrist',     title: '低糖質宅食おすすめ｜糖質制限向け3選の比較',       badge: '低糖質' },
      { slug: 'nashi-review-drama',                            title: 'ナッシュ口コミ｜3ヶ月使った正直レビュー',         badge: 'ナッシュ' },
    ],
    books: [
      { num: 'book20', asin: 'B0H2S1PM6P', title: '宅食サービス7社を使い続けた記録 — PM目線の本音比較', desc: 'ナッシュ・ワタミ・nosh・三ツ星ファームなど7社を半年間継続使用。コスト・栄養・利便性を本音で比較した記録。', badge: '宅食比較' },
    ],
    productsLabel: '書籍で紹介する宅食サービス',
    products: [
      { name: 'ヨシケイ（ミールキット）', href: 'https://px.a8.net/svt/ejp?a8mat=4B1RXQ+8MSAK2+1QM6+I7FOH', desc: '食材・調味料がセットで届くミールキット。買い物不要で帰宅後20〜30分で調理が完了。書籍で比較した7社のうち、コスパと調理ハードルのバランスが取りやすいサービス。', badge: 'ミールキット', cta: '公式サイトへ →' },
      { name: 'マッスルデリ（低糖質宅食）', href: 'https://px.a8.net/svt/ejp?a8mat=4B1RXQ+8L00II+4CPY+5YRHE', desc: '高たんぱく・低糖質設計の冷凍宅食。レンジ5分で完成。体型を管理しながら食事の準備時間をゼロにしたい人向け。', badge: '低糖質', cta: '公式サイトへ →' },
      { name: 'わんまいる 健幸ディナー', href: 'https://px.a8.net/svt/ejp?a8mat=4B1RXQ+ASS3KQ+2SIM+609HU', desc: '1食ごとに冷凍された副菜セットの和食宅食。湯せん5分で本格的な夕食が完成する。高齢の家族への仕送りにも向く。', badge: '和食宅配', cta: '公式サイトへ →' },
    ],
  },
  {
    id: 'health',
    label: '健康・栄養管理',
    emoji: '🥗',
    alt: false,
    desc: '腸活・疲労回復・糖質制限・健康診断の数値改善など、体の状態を食事で整えるテーマの本です。',
    articles: [
      { slug: 'gut-brain-axis-psychiatrist',             title: '腸脳相関と食事｜腸内環境がメンタルに与える影響',     badge: '腸活' },
      { slug: 'chronic-fatigue-diet-guide-psychiatrist', title: '慢性疲労と食事改善｜疲れが取れない理由',             badge: '疲労回復' },
      { slug: 'ldl-cholesterol-food-psychiatrist',       title: 'LDLコレステロールを下げる食事｜食材の選び方',       badge: 'コレステロール' },
      { slug: 'pms-iron-diet-psychiatrist',              title: 'PMS前の鉄分不足と食事設計',                       badge: 'PMS' },
      { slug: 'summer-hydration-electrolyte-psychiatrist', title: '夏の水分補給と電解質｜熱中症・夏バテを防ぐ', badge: '夏バテ対策' },
    ],
    books: [
      { num: 'book17',  asin: 'B0H2RRLKR9', title: '腸活レシピ入門 腸内環境を整える食事習慣',                    desc: '腸内環境が整うと疲れにくくなる。食物繊維・発酵食品の取り方と、続けやすい腸活レシピを紹介。',                                           badge: '腸活' },
      { num: 'book70',  asin: 'B0H3JZHNPP', title: '疲労回復ごはん 仕事で疲れた日に食べる栄養満点レシピ',        desc: '疲労回復に効くビタミンB群・鉄・亜鉛を日常食で取る方法。仕事帰りに「これを食べれば回復できる」レシピ集。',                               badge: '疲労回復' },
      { num: 'book71',  asin: 'B0H25RFD55', title: 'ゆるい糖質制限 我慢しない食べ方で体重を落とす',              desc: '極端な糖質カットなしに体重を管理する方法。「食べていいもの・控えるもの」を明快に整理した入門書。',                                       badge: '糖質制限' },
      { num: 'book74',  asin: 'B0H24395ZM', title: '健康診断の数値を食事で改善するコレステロール・血糖値対策',    desc: 'LDLコレステロール・血糖値・中性脂肪を食事でコントロール。健診結果を見ながら取り組める実践ガイド。',                                       badge: '健康診断' },
      { num: 'book79',  asin: 'B0H2T55QKV', title: 'PMSをやわらげる食事の本',                                   desc: '月経前の不調（イライラ・むくみ・過食）を食事でやわらげる。マグネシウム・ビタミンB6など栄養素別に解説。',                               badge: 'PMS' },
      { num: 'book120', asin: 'B0H41395P2', title: '夏バテしない食事の本',                                       desc: '夏の食欲低下・倦怠感を食事でケアする。冷たいものを食べすぎない工夫と、体を冷やしすぎない献立設計。',                                     badge: '夏バテ' },
    ],
    productsLabel: '書籍で紹介するサプリ・健康食品',
    products: [
      { name: 'Myprotein（プロテイン）', href: 'https://px.a8.net/svt/ejp?a8mat=4B1RXQ+8NDQ5U+45DI+60H7M', desc: '食事だけではたんぱく質が不足しがちな日の補助に。ヨーグルト・牛乳に溶かすだけで手軽に補給できる国際的ブランド。疲労回復・腸活レシピと組み合わせて活用できる。', badge: 'たんぱく質', cta: '公式サイトへ →' },
      { name: 'アルロース専門店（低GI甘味料）', href: 'https://px.a8.net/svt/ejp?a8mat=4B1THV+3258GQ+1CFC+1THW9E', desc: '砂糖の代わりに使える低GI甘味料。血糖値スパイクを緩やかにしながら甘さを楽しめる。糖質制限・コレステロール管理中の料理・スイーツ作りに。', badge: '低GI', cta: '公式サイトへ →' },
    ],
  },
];

const allBooks = SECTIONS.flatMap(s => s.books);
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "時短×健康 Kindle本ガイド — 宮本ユウカの全著作一覧",
  "description": "時短料理・宅食・健康管理をテーマにした全20冊のKindle本を一覧で紹介。忙しい30代・40代の食生活を楽にする本を、テーマ別に分類しています。",
  "url": "https://jitan-kenko.blog/kindle-guide/",
  "hasPart": allBooks.map(b => ({
    "@type": "Book",
    "name": b.title,
    "url": `https://www.amazon.co.jp/dp/${b.asin}/`,
  }))
});
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P6YC8SXBSH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-P6YC8SXBSH');
    </script>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9842738692752047"
         crossorigin="anonymous"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kindle本ガイド — 時短×健康の全著作20冊 | 時短 × 健康</title>
    <meta name="description" content="時短料理・宅食・健康管理をテーマにした全20冊のKindle本一覧。忙しい30代・40代の食生活を楽にする本を、テーマ別にまとめました。著者：宮本ユウカ。" />
    <link rel="canonical" href="https://jitan-kenko.blog/kindle-guide/" />
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body>

    <header class="site-header">
      <div class="container header-container">
        <a href="/" class="brand">
          <span class="brand-name">時短 × 健康</span>
          <span class="brand-sub">ー忙しい大人のための合理的食生活ー</span>
        </a>
        <nav class="header-cat-nav" aria-label="カテゴリ">
          <a href="/comparison/"    class="header-cat-link"><span>📊</span><span>比較</span></a>
          <a href="/review/"        class="header-cat-link"><span>🍱</span><span>レビュー</span></a>
          <a href="/health-column/" class="header-cat-link"><span>🥗</span><span>健康コラム</span></a>
          <a href="/howto/"         class="header-cat-link"><span>⚙️</span><span>仕組み化</span></a>
          <a href="/mental-health/" class="header-cat-link"><span>🧠</span><span>メンタル</span></a>
          <a href="/articles/"      class="header-cat-link header-cat-link--all"><span>📋</span><span>全記事</span></a>
        </nav>
      </div>
    </header>

    <main>

      <section class="page-hero">
        <div class="container">
          <p class="page-breadcrumb"><a href="/">ホーム</a> › Kindle本ガイド</p>
          <h1 class="page-title">📚 Kindle本ガイド</h1>
          <p class="page-lead">時短 × 健康ブログの著者・宮本ユウカが書いた全20冊をテーマ別に一覧にしています。<br>
          各テーマの詳しい解説記事もあわせて読むと、本の内容がより深く理解できます。</p>
          <div class="ku-note">
            <span class="ku-badge">KU</span>
            <span>Kindle Unlimited 読み放題プラン対象。月額980円で全冊読み放題。</span>
          </div>
        </div>
      </section>

      <!-- こんだてガチャ送客（双方向連携・献立を決める導線） -->
      <section class="app-cta-section">
        <div class="container">
          <a
            href="https://play.google.com/store/apps/details?id=com.kondategacha.app&referrer=utm_source%3Djitan-kenko%26utm_medium%3Dreferral%26utm_campaign%3Dkindle-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="app-cta-box"
            aria-label="こんだてガチャをダウンロード（無料・新しいタブ）"
          >
            <span class="app-cta-icon">
              <img src="/images/kondate-gacha-icon.png" alt="こんだてガチャ" width="56" height="56" />
            </span>
            <span class="app-cta-body">
              <span class="app-cta-tag">無料アプリ</span>
              <span class="app-cta-title">今日の献立、3秒で決まる「こんだてガチャ」</span>
              <span class="app-cta-desc">「何作ろう…」と毎日悩んでいませんか？食べたいジャンルを選んでガチャを回すだけで、今日の献立が一瞬で決まります。本を読む前に、まずインストールしてみてください。</span>
            </span>
            <span class="app-cta-btn">Google Playで無料DL →</span>
          </a>
        </div>
      </section>

      {SECTIONS.map(sec => (
        <section class:list={['book-section', sec.alt && 'book-section--alt']} id={sec.id}>
          <div class="container">
            <h2 class="section-title">
              <span class="section-icon">{sec.emoji}</span>
              {sec.label}
              <span class="section-count">{sec.books.length}冊</span>
            </h2>
            <p class="section-desc">{sec.desc}</p>

            <!-- 層1: 関連記事（主収益源） -->
            <div class="layer-header">
              <span class="layer-icon">📖</span>
              <span class="layer-label-text">詳しい解説記事を読む</span>
            </div>
            <div class="article-grid">
              {sec.articles.map(a => (
                <a href={articleUrl(a.slug)} class="article-link">
                  <span class="article-badge">{a.badge}</span>
                  <span class="article-title">{a.title}</span>
                  <span class="article-cta">読む →</span>
                </a>
              ))}
            </div>

            <!-- 層2: 関連Kindle本（クロスセル） -->
            <div class="layer-header layer-header--books">
              <span class="layer-icon">📕</span>
              <span class="layer-label-text">関連Kindle本</span>
            </div>
            <div class="book-grid">
              {sec.books.map(b => (
                <a href={amazonUrl(b.asin, b.num)} target="_blank" rel="sponsored noopener noreferrer" class="book-card">
                  <div class="book-card-inner">
                    <span class="book-badge">{b.badge}</span>
                    <h3 class="book-title">{b.title}</h3>
                    <p class="book-desc">{b.desc}</p>
                    <span class="book-cta">Amazonで見る →</span>
                  </div>
                </a>
              ))}
            </div>

            <!-- 層3: 関連グッズ（書籍で紹介する道具・サービス） -->
            {'products' in sec && sec.products && sec.products.length > 0 && (
              <>
                <div class="layer-header layer-header--products">
                  <span class="layer-icon">🛒</span>
                  <span class="layer-label-text">{(sec as any).productsLabel ?? '書籍で紹介するグッズ'}</span>
                </div>
                <div class="book-grid">
                  {sec.products.map((p: { name: string; href: string; desc: string; badge: string; cta?: string }) => (
                    <a href={p.href} target="_blank" rel="sponsored noopener noreferrer" class="book-card product-card">
                      <div class="book-card-inner">
                        <span class="book-badge product-badge">{p.badge}</span>
                        <h3 class="book-title">{p.name}</h3>
