---
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => data.humanReviewed === true);
const sorted = allArticles.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categoryMeta: Record<string, { label: string; icon: string; color: string }> = {
  comparison:      { label: '比較記事',      icon: '📊', color: '#1b3f6e' },
  review:          { label: 'レビュー',      icon: '🍱', color: '#c4703b' },
  'health-column': { label: '健康コラム',    icon: '🥗', color: '#2d8b72' },
  howto:           { label: '仕組み化',      icon: '⚙️', color: '#3b5f8b' },
  'mental-health': { label: 'メンタルヘルス', icon: '🧠', color: '#7c3aed' },
};

// カテゴリ別にグループ化
const byCategory: Record<string, typeof sorted> = {};
for (const a of sorted) {
  const c = a.data.category;
  if (!byCategory[c]) byCategory[c] = [];
  byCategory[c].push(a);
}

const url = 'https://jitan-kenko.blog/articles/';
const title = '全記事一覧 | 時短 × 健康';
const description = '時短×健康ブログの全記事一覧。比較・レビュー・健康コラム・仕組み化・メンタルヘルスの5カテゴリで全記事を探せます。';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P6YC8SXBSH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-P6YC8SXBSH');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="時短 × 健康" />
    <meta property="og:locale" content="ja_JP" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand">
          <span class="brand-name">時短 × 健康</span>
          <span class="brand-sub">ー忙しい大人のための合理的食生活ー</span>
        </a>
      </div>
    </header>

    <main class="all-main">
      <div class="container">
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <ol>
            <li><a href="/">トップ</a></li>
            <li aria-current="page">全記事一覧</li>
          </ol>
        </nav>

        <header class="all-hero">
          <h1>全記事一覧（{sorted.length}件）</h1>
          <p>カテゴリで絞り込むか、下のリストから探してください。</p>
          <div class="cat-quick">
            {Object.entries(categoryMeta).map(([k, v]) => (
              <a href={`/${k}/`} class="cat-quick-link">
                <span>{v.icon}</span>
                <span>{v.label}</span>
                <span class="cat-quick-count">{(byCategory[k] || []).length}</span>
              </a>
            ))}
          </div>
        </header>

        {Object.entries(categoryMeta).map(([cat, meta]) => {
          const list = byCategory[cat] || [];
          if (list.length === 0) return null;
          return (
            <section class="cat-section">
              <h2 class="cat-section-title" style={`border-left-color:${meta.color}`}>
                <span>{meta.icon}</span>
                <a href={`/${cat}/`}>{meta.label}</a>
                <span class="cat-section-count">（{list.length}件）</span>
              </h2>
              <ul class="cat-section-list">
                {list.map(a => (
                  <li>
                    <a href={`/articles/${a.slug}/`} class="cat-section-card">
                      <span class="arrow">→</span>
                      <span>{a.data.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          );
        })}
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>&copy; 2026 時短 × 健康</p>
        <nav>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/about">このブログについて</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
        <p class="affiliate-disclaimer">当サイトはA8.net等のアフィリエイトプログラムに参加しています。</p>
      </div>
    </footer>
  </body>
</html>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Hiragino Kaku Gothic ProN','Noto Sans JP','Yu Gothic Medium',sans-serif;background:#f7f5f1;color:#212b38;line-height:1.85;-webkit-font-smoothing:antialiased;}
a{color:inherit;text-decoration:none;}
.container{max-width:860px;margin:0 auto;padding:0 1.25rem;}
.site-header{background:#0f2545;padding:0.9rem 0;position:sticky;top:0;z-index:100;box-shadow:0 4px 16px rgba(0,0,0,.3);}
.brand{display:flex;flex-direction:column;gap:0.05rem;}
.brand-name{color:#fff;font-size:1.1rem;font-weight:800;}
.brand-sub{color:#93c5fd;font-size:0.68rem;}
.all-main{padding:2rem 0 5rem;min-height:70vh;}
.breadcrumb ol{list-style:none;display:flex;flex-wrap:wrap;gap:0.2rem;font-size:0.75rem;color:#536070;margin-bottom:1.25rem;}
.breadcrumb a{color:#536070;}
.breadcrumb a:hover{color:#1b3f6e;}
.breadcrumb li+li::before{content:' › ';opacity:.5;}
.all-hero{background:#fff;border:1px solid #e0dbd2;border-radius:10px;padding:1.5rem;margin-bottom:1.75rem;}
.all-hero h1{font-size:1.4rem;font-weight:800;color:#1b3f6e;margin-bottom:0.5rem;letter-spacing:-0.01em;}
.all-hero p{font-size:0.88rem;color:#536070;margin-bottom:1.1rem;}
.cat-quick{display:flex;flex-wrap:wrap;gap:0.45rem;}
.cat-quick-link{display:inline-flex;align-items:center;gap:0.4rem;background:#f7f5f1;border:1px solid #e0dbd2;border-radius:20px;padding:0.4rem 0.95rem;font-size:0.82rem;font-weight:600;color:#1b3f6e;transition:background .15s,border-color .15s,transform .15s;}
.cat-quick-link:hover{background:#fdf0e6;border-color:#c4703b;color:#c4703b;transform:translateY(-1px);}
.cat-quick-count{background:#1b3f6e;color:#fff;font-size:0.7rem;padding:0.05rem 0.5rem;border-radius:10px;font-weight:700;}
.cat-quick-link:hover .cat-quick-count{background:#c4703b;}
.cat-section{margin-bottom:2.5rem;}
.cat-section-title{font-size:1.1rem;font-weight:800;color:#1b3f6e;display:flex;align-items:center;gap:0.55rem;padding-left:0.75rem;border-left:4px solid #1b3f6e;margin-bottom:0.85rem;}
.cat-section-title a{color:#1b3f6e;text-decoration:none;}
.cat-section-title a:hover{color:#c4703b;text-decoration:underline;}
.cat-section-count{font-size:0.75rem;font-weight:600;color:#8fa0b0;}
.cat-section-list{list-style:none;display:flex;flex-direction:column;gap:0.4rem;}
.cat-section-card{display:flex;align-items:flex-start;gap:0.55rem;background:#fff;border:1px solid #e0dbd2;border-radius:6px;padding:0.7rem 0.95rem;font-size:0.9rem;color:#1b3f6e;font-weight:500;line-height:1.55;transition:border-color .15s,background .15s;}
.cat-section-card:hover{background:#fdf0e6;border-color:#c4703b;color:#c4703b;}
.cat-section-card .arrow{color:#1b3f6e;flex-shrink:0;margin-top:0.05rem;}
.cat-section-card:hover .arrow{color:#c4703b;}
.site-footer{background:#0f2545;color:#94a3b8;padding:2rem 0;font-size:0.78rem;}
.footer-inner{display:flex;flex-direction:column;gap:0.65rem;}
.footer-inner nav{display:flex;gap:1.25rem;flex-wrap:wrap;}
.footer-inner nav a{color:#94a3b8;}
.footer-inner nav a:hover{color:#e2e8f0;}
.affiliate-disclaimer{font-size:0.68rem;color:#475569;}
</style>
