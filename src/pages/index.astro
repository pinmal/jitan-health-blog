---
import { getCollection } from 'astro:content';
import { generateSiteSchema } from '../utils/schema';
import KondateGachaCTA from '../components/KondateGachaCTA.astro';

const allArticles = await getCollection('articles', ({ data }) => data.humanReviewed === true);
const sortedAll = allArticles.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const yukaArticles  = sortedAll.filter(a => !a.data.character || a.data.character === 'yuka');
const naokoArticles = sortedAll.filter(a => a.data.character === 'naoko');
const kenjiArticles = sortedAll.filter(a => a.data.character === 'kenji');

const featured = allArticles.find(a => a.data.isFeatured) ?? sortedAll[0];
const siteSchema = generateSiteSchema();

const purposes = [
  { id: 'all',       label: 'すべて',           icon: '📋' },
  { id: 'no-cook',   label: '夕食を作りたくない',  icon: '🍱' },
  { id: 'nutrition', label: '栄養・疲れ改善',     icon: '🥗' },
  { id: 'sleep',     label: '睡眠・メンタル',     icon: '😴' },
  { id: 'diet',      label: 'ダイエット・体型',   icon: '💪' },
  { id: 'compare',   label: 'サービス比較',       icon: '📊' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P6YC8SXBSH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-P6YC8SXBSH');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>時短 × 健康 — 忙しい大人のための合理的食生活</title>
    <meta name="description" content="体や心の調子が落ちているとき、献立を決めること・調理の段取りを組むことは難しくなります。精神保健指定医の長友恭平が、状態に合った自己管理の一つとして宅配食・栄養補助食品の活用法を解説します。" />
    <link rel="canonical" href="https://jitan-kenko.blog/" />
    <script type="application/ld+json" set:html={siteSchema} />
  </head>
  <body>

    <header class="site-header">
      <div class="container">
        <a href="/" class="brand">
          <span class="brand-name">時短 × 健康</span>
          <span class="brand-sub">ー忙しい大人のための合理的食生活ー</span>
        </a>
      </div>
    </header>

    <main>

      <!-- Hero -->
      <section class="hero">
        <div class="container">
          <h2 class="hero-heading">「健康的に食べたいけど、毎日の献立を考えるのが面倒」</h2>
          <p class="hero-sub">宅配食・栄養補助食品・こんだて提案で仕組み化すると、<strong>意思決定の負荷が下がります。</strong></p>
          <div class="hero-body">
            <p>体や心の調子が落ちているとき、献立を決めること・調理の段取りを組むことは、思いのほか難しくなります。食欲がないわけではなくても、「何を作るか考える」「材料を買いに行く」「手順どおりに調理する」——この一連のプロセスが、意欲や判断力の低下した状態では相当なエネルギーを必要とするためです。</p>
            <p>「楽をするため」ではなく、<strong>今の自分の状態に合った自己管理の一つとして</strong>——宅配食・栄養補助食品・献立の仕組み化を活用してください。</p>
          </div>
          <KondateGachaCTA context="weekly-plan" />
        </div>
      </section>

      <!-- 目的別フィルタ -->
      <section class="purpose-section">
        <div class="container">
          <p class="purpose-label">いまの目的から探す</p>
          <div class="purpose-bar" role="group" aria-label="目的で絞り込む">
            {purposes.map(p => (
              <button
                class={`purpose-chip${p.id === 'all' ? ' active' : ''}`}
                data-filter={p.id}
                type="button"
                aria-pressed={p.id === 'all' ? 'true' : 'false'}
              >
                <span class="purpose-icon">{p.icon}</span>
                <span>{p.label}</span>
              </button>
            ))}
          </div>
          <p class="filter-status" id="filter-status" aria-live="polite"></p>
        </div>
      </section>

      <!-- ユウカ -->
      {yukaArticles.length > 0 && (
        <section class="section-articles section-yuka" data-char="yuka">
          <div class="container">
            <div class="section-header-row">
              <h2 class="section-heading section-heading--yuka">
                <span class="char-avatar char-avatar--yuka">ユ</span>
                <span>宮本ユウカの記録</span>
                <span class="article-count-badge">{yukaArticles.length}件</span>
              </h2>
              <button class="section-toggle" data-target="yuka" aria-expanded="true" type="button">
                <span class="toggle-icon">▲</span> たたむ
              </button>
            </div>
            <div class="section-collapsible" id="collapse-yuka">
              <p class="char-profile">34歳・IT企業・一人暮らし。仕事が忙しくて食事が後回しになりがち。「健康的に食べたいけど、毎日考えるのが面倒」という読者の分身。</p>
              <div class="article-grid" id="grid-yuka">
                {yukaArticles.map((article, i) => (
                  <a
                    href={`/articles/${article.slug}/`}
                    class={`article-card article-card--yuka${i >= 6 ? ' card-extra' : ''}`}
                    data-tags={(article.data.tags ?? []).join(',')}
                    data-category={article.data.category}
                  >
                    <h3 class="article-title">{article.data.title}</h3>
                    <time class="article-date" datetime={article.data.publishedAt.toISOString()}>
                      {article.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </a>
                ))}
              </div>
              {yukaArticles.length > 6 && (
                <button class="more-btn" data-grid="yuka" type="button">
                  もっと見る（+{yukaArticles.length - 6}件）
                </button>
              )}
            </div>
          </div>
        </section>
      )}

      <!-- ナオコ -->
      {naokoArticles.length > 0 && (
        <section class="section-articles section-naoko" data-char="naoko">
          <div class="container">
            <div class="section-header-row">
              <h2 class="section-heading section-heading--naoko">
                <span class="char-avatar char-avatar--naoko">ナ</span>
                <span>田中ナオコの記録</span>
                <span class="article-count-badge">{naokoArticles.length}件</span>
              </h2>
              <button class="section-toggle" data-target="naoko" aria-expanded="true" type="button">
                <span class="toggle-icon">▲</span> たたむ
              </button>
            </div>
            <div class="section-collapsible" id="collapse-naoko">
              <p class="char-profile">38歳・ITコンサル・一人暮らし。健康意識が高めでコスパ感覚が鋭い。ユウカより少し先を行く先輩。情報収集してから決めるタイプ。</p>
              <div class="article-grid" id="grid-naoko">
                {naokoArticles.map((article, i) => (
                  <a
                    href={`/articles/${article.slug}/`}
                    class={`article-card article-card--naoko${i >= 6 ? ' card-extra' : ''}`}
                    data-tags={(article.data.tags ?? []).join(',')}
                    data-category={article.data.category}
                  >
                    <h3 class="article-title">{article.data.title}</h3>
                    <time class="article-date" datetime={article.data.publishedAt.toISOString()}>
                      {article.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </a>
                ))}
              </div>
              {naokoArticles.length > 6 && (
                <button class="more-btn" data-grid="naoko" type="button">
                  もっと見る（+{naokoArticles.length - 6}件）
                </button>
              )}
            </div>
          </div>
        </section>
      )}

      <!-- ケンジ -->
      {kenjiArticles.length > 0 && (
        <section class="section-articles section-kenji" data-char="kenji">
          <div class="container">
            <div class="section-header-row">
              <h2 class="section-heading section-heading--kenji">
                <span class="char-avatar char-avatar--kenji">ケ</span>
                <span>井上ケンジの記録</span>
                <span class="article-count-badge">{kenjiArticles.length}件</span>
              </h2>
              <button class="section-toggle" data-target="kenji" aria-expanded="true" type="button">
                <span class="toggle-icon">▲</span> たたむ
              </button>
            </div>
            <div class="section-collapsible" id="collapse-kenji">
              <p class="char-profile">41歳・大手メーカー部長・共働き4人家族。「子供が食べてくれるか」が判断基準。コスト計算が得意で、続けられる仕組みを重視する。</p>
              <div class="article-grid" id="grid-kenji">
                {kenjiArticles.map((article, i) => (
                  <a
                    href={`/articles/${article.slug}/`}
                    class={`article-card article-card--kenji${i >= 6 ? ' card-extra' : ''}`}
                    data-tags={(article.data.tags ?? []).join(',')}
                    data-category={article.data.category}
                  >
                    <h3 class="article-title">{article.data.title}</h3>
                    <time class="article-date" datetime={article.data.publishedAt.toISOString()}>
                      {article.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </a>
                ))}
              </div>
              {kenjiArticles.length > 6 && (
                <button class="more-btn" data-grid="kenji" type="button">
                  もっと見る（+{kenjiArticles.length - 6}件）
                </button>
              )}
            </div>
          </div>
        </section>
      )}

      <!-- フィルタ結果が0件の場合 -->
      <div class="no-results" id="no-results" style="display:none">
        <div class="container">
          <p>該当する記事が見つかりませんでした。</p>
          <button class="reset-filter-btn" type="button">すべての記事を表示</button>
        </div>
      </div>

      <!-- Featured Article -->
      {featured && (
        <section class="section-featured">
          <div class="container">
            <h2 class="section-heading"><span>一番人気の記事</span></h2>
            <a href={`/articles/${featured.slug}/`} class="featured-card">
              <div class="featured-body">
                <h3 class="featured-title">{featured.data.title}</h3>
                <time class="article-date" datetime={featured.data.publishedAt.toISOString()}>
                  {featured.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <span class="featured-arrow">→</span>
            </a>
          </div>
        </section>
      )}

      <!-- Categories (フィルタトリガー) -->
      <section class="section-categories">
        <div class="container">
          <h2 class="section-heading-sm">カテゴリから探す</h2>
          <div class="category-list">
            {[
              { filter: 'compare',   label: '比較記事',   icon: '📊' },
              { filter: 'no-cook',   label: '宅食・時短',  icon: '🍱' },
              { filter: 'nutrition', label: '栄養コラム', icon: '🥗' },
              { filter: 'sleep',     label: 'メンタル',   icon: '🧠' },
              { filter: 'diet',      label: '運動・体型', icon: '💪' },
            ].map(cat => (
              <button class="category-chip js-cat-filter" data-filter={cat.filter} type="button">
                <span class="chip-icon">{cat.icon}</span>
                <span class="chip-label">{cat.label}</span>
              </button>
            ))}
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <p class="footer-name">時短 × 健康</p>
          <p class="footer-copy">&copy; 2026 時短 × 健康</p>
        </div>
        <nav class="footer-nav">
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/about">このブログについて</a>
          <a href="/contact">お問い合わせ</a>
          <a href="https://drnagatomo2026.com" target="_blank" rel="noopener noreferrer">監修医の医療ブログ</a>
        </nav>
        <p class="footer-affiliate">当サイトはA8.net等のアフィリエイトプログラムに参加しています。</p>
      </div>
    </footer>

  </body>
</html>

<script is:inline>
(function () {
  // ── フィルタ定義 ──────────────────────────────────────────────
  const filterMap = {
    'no-cook':   ['宅食', '冷凍弁当', '時短', 'ミールキット', '仕組み化', '夕食管理', '食材宅配', '宅食弁当', '宅配弁当', '作り置き'],
    'nutrition': ['タンパク質', '栄養', '疲れ', '腸脳相関', '鉄分', '食事管理', '高タンパク', '魚', '野菜', '有機'],
    'sleep':     ['睡眠', 'ストレス食い', 'カフェイン', 'メラトニン', 'メンタルヘルス', 'コーヒー', 'ストレス'],
    'diet':      ['ダイエット', '高タンパク', '低糖質', '筋トレ', 'フィットネス', 'ジム', 'プロテイン', '運動'],
    'compare':   ['比較'],
  };

  function matchesFilter(filter, tagsStr, category) {
    if (filter === 'all') return true;
    if (filter === 'compare') return category === 'comparison' || tagsStr.includes('比較');
    const keywords = filterMap[filter] || [];
    return keywords.some(kw => tagsStr.includes(kw));
  }

  // ── 状態 ─────────────────────────────────────────────────────
  let currentFilter = 'all';
  const expandedGrids = new Set(); // 「もっと見る」押されたグリッドID

  function applyFilter(filter) {
    currentFilter = filter;

    // カードの表示切り替え
    document.querySelectorAll('.article-card').forEach(card => {
      const tagsStr = card.dataset.tags || '';
      const category = card.dataset.category || '';
      const matches = matchesFilter(filter, tagsStr, category);

      if (filter === 'all') {
        // グリッドごとに展開済みか判断
        const grid = card.closest('.article-grid');
        const gridId = grid ? grid.id.replace('grid-', '') : '';
        const isExtra = card.classList.contains('card-extra');
        card.style.display = (isExtra && !expandedGrids.has(gridId)) ? 'none' : '';
      } else {
        card.style.display = matches ? '' : 'none';
      }
    });

    // 「もっと見る」ボタンはall時のみ表示
    document.querySelectorAll('.more-btn').forEach(btn => {
      if (filter === 'all') {
        const gridId = btn.dataset.grid;
        btn.style.display = expandedGrids.has(gridId) ? 'none' : '';
      } else {
        btn.style.display = 'none';
      }
    });

    // セクションの空チェック
    let totalVisible = 0;
    document.querySelectorAll('.section-articles').forEach(section => {
      const grid = section.querySelector('.article-grid');
      if (!grid) return;
      // 折りたたみ中は除外
      const collapseEl = section.querySelector('.section-collapsible');
      if (collapseEl && collapseEl.style.display === 'none') return;

      const visible = Array.from(grid.querySelectorAll('.article-card'))
        .filter(c => c.style.display !== 'none').length;
      section.style.display = visible > 0 ? '' : 'none';
      totalVisible += visible;
    });

    // 0件表示
    const noResults = document.getElementById('no-results');
    if (noResults) noResults.style.display = totalVisible === 0 ? '' : 'none';

    // ステータス文
    const status = document.getElementById('filter-status');
    if (status) {
      if (filter === 'all') {
        status.textContent = '';
      } else {
        const purposeBtn = document.querySelector(`.purpose-chip[data-filter="${filter}"]`);
        const label = purposeBtn ? purposeBtn.querySelector('span:last-child').textContent : '';
        status.textContent = totalVisible > 0
          ? `「${label}」に関連する記事 ${totalVisible}件`
          : `「${label}」に関連する記事は見つかりませんでした`;
      }
    }
  }

  // ── 目的フィルタ ─────────────────────────────────────────────
  document.querySelectorAll('.purpose-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.purpose-chip').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      applyFilter(btn.dataset.filter);
    });
  });

  // ── カテゴリボタン（下部セクション → フィルタと連動） ──────────
  document.querySelectorAll('.js-cat-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      // purpose-chip と同じ処理
      document.querySelectorAll('.purpose-chip').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      const targetChip = document.querySelector(`.purpose-chip[data-filter="${filter}"]`);
      if (targetChip) { targetChip.classList.add('active'); targetChip.setAttribute('aria-pressed', 'true'); }
      applyFilter(filter);
      // フィルタバーまでスクロール
      const purposeSection = document.querySelector('.purpose-section');
      if (purposeSection) purposeSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // リセットボタン
  document.querySelectorAll('.reset-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.purpose-chip').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      const allChip = document.querySelector('.purpose-chip[data-filter="all"]');
      if (allChip) { allChip.classList.add('active'); allChip.setAttribute('aria-pressed', 'true'); }
      applyFilter('all');
    });
  });

  // ── もっと見る ───────────────────────────────────────────────
  document.querySelectorAll('.more-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const gridId = btn.dataset.grid;
      expandedGrids.add(gridId);
      const grid = document.getElementById(`grid-${gridId}`);
      if (grid) {
        grid.querySelectorAll('.card-extra').forEach(c => c.style.display = '');
      }
      btn.style.display = 'none';
    });
  });

  // ── セクション折りたたみ ─────────────────────────────────────
  document.querySelectorAll('.section-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      const collapseEl = document.getElementById(`collapse-${target}`);
      if (!collapseEl) return;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';

      if (isExpanded) {
        collapseEl.style.display = 'none';
        btn.setAttribute('aria-expanded', 'false');
        btn.innerHTML = '<span class="toggle-icon">▼</span> 広げる';
      } else {
        collapseEl.style.display = '';
        btn.setAttribute('aria-expanded', 'true');
        btn.innerHTML = '<span class="toggle-icon">▲</span> たたむ';
        // 再表示後にフィルタ再適用
        applyFilter(currentFilter);
      }
    });
  });

  // 初期状態：card-extraを非表示
  document.querySelectorAll('.card-extra').forEach(c => c.style.display = 'none');
})();
</script>

<style>
/* ══════════════════════════════════════
   Design System — 時短×健康ブログ
   Concept: Warm Clinical
   Primary: Deep Navy  Accent: Terracotta
══════════════════════════════════════ */
:root {
  --c-primary:      #1b3f6e;
  --c-primary-dk:   #0f2545;
  --c-primary-md:   #2d6090;
  --c-accent:       #c4703b;
  --c-accent-lt:    #fdf0e6;
  --c-bg:           #f7f5f1;
  --c-bg-white:     #ffffff;
  --c-bg-alt:       #eeeae3;
  --c-text:         #212b38;
  --c-text-md:      #536070;
  --c-text-lt:      #8fa0b0;
  --c-border:       #e0dbd2;
  --c-shadow-sm:    0 2px 10px rgba(27,63,110,.07);
  --c-shadow-md:    0 4px 24px rgba(27,63,110,.11);
  --r:              10px;
  --r-sm:           6px;
  --max-w:          1080px;
  --max-w-text:     720px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Kaku Gothic ProN',
               'Noto Sans JP', 'Yu Gothic Medium', sans-serif;
  background: var(--c-bg);
  color: var(--c-text);
  line-height: 1.8;
  -webkit-font-smoothing: antialiased;
}
a { color: inherit; text-decoration: none; }
.container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }

/* ── Header ────────────────────── */
.site-header {
  background: var(--c-primary-dk);
  padding: 1rem 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 1px 0 rgba(255,255,255,.05), 0 4px 16px rgba(0,0,0,.3);
}
.brand { display: flex; flex-direction: column; gap: 0.1rem; }
.brand-name { font-size: 1.2rem; font-weight: 800; color: #fff; letter-spacing: -0.01em; line-height: 1.2; }
.brand-sub { font-size: 0.7rem; color: #93c5fd; font-weight: 400; }

/* ── Hero ──────────────────────── */
.hero {
  background: var(--c-bg-white);
  border-bottom: 1px solid var(--c-border);
  padding: 2.75rem 0 2.25rem;
}
.hero-heading { font-size: 1.35rem; font-weight: 700; color: var(--c-text); line-height: 1.5; margin-bottom: 0.65rem; max-width: var(--max-w-text); }
.hero-sub { font-size: 1rem; font-weight: 600; color: var(--c-text); margin-bottom: 1.25rem; line-height: 1.6; }
.hero-sub strong { color: var(--c-primary); }
.hero-body { max-width: var(--max-w-text); font-size: 0.93rem; line-height: 1.9; color: var(--c-text-md); margin-bottom: 1.75rem; }
.hero-body p { margin-bottom: 0.85rem; }
.hero-body p:last-child { margin-bottom: 0; }
.hero-body strong { color: var(--c-text); }

/* ── Purpose Filter Bar ────────── */
.purpose-section {
  background: var(--c-bg-white);
  border-bottom: 2px solid var(--c-border);
  padding: 1rem 0 0.85rem;
  position: sticky;
  top: 56px;
  z-index: 90;
  box-shadow: 0 2px 8px rgba(0,0,0,.06);
}
.purpose-label {
  font-size: 0.7rem;
  font-weight: 700;
