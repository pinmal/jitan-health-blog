---
interface Props {
  href: string;
  brand: string;
  catchcopy: string;
  imageSrc?: string;
  imageAlt?: string;
  price?: string;
  features?: string[];
  badge?: string;
  platform?: string;
  accentColor?: string;
}

const {
  href,
  brand,
  catchcopy,
  imageSrc,
  imageAlt,
  price,
  features = [],
  badge,
  platform = 'A8.net',
  accentColor = '#1b3f6e',
} = Astro.props;
---

<div class="aff-card">
  {/* 画像エリア */}
  <div class="aff-img-wrap" style={`--accent: ${accentColor}`}>
    {imageSrc
      ? <img src={imageSrc} alt={imageAlt ?? brand} loading="lazy" class="aff-img" />
      : <div class="aff-img-placeholder">
          <span class="aff-brand-initial">{brand.charAt(0)}</span>
          <span class="aff-brand-name-bg">{brand}</span>
        </div>
    }
    {badge && <span class="aff-badge">{badge}</span>}
  </div>

  {/* 本文エリア */}
  <div class="aff-body">
    <p class="aff-brand">{brand}</p>
    <p class="aff-catch">{catchcopy}</p>

    {price && <p class="aff-price">{price}</p>}

    {features.length > 0 && (
      <ul class="aff-features">
        {features.map(f => <li>{f}</li>)}
      </ul>
    )}

    <a href={href} class="aff-btn" target="_blank" rel="noopener noreferrer nofollow" style={`--accent: ${accentColor}`}>
      公式サイトをみる →
    </a>
    <p class="aff-disc">※ アフィリエイト広告（{platform}）</p>
  </div>
</div>

<style>
.aff-card {
  border: 1px solid #e0dbd2;
  border-radius: 10px;
  overflow: hidden;
  margin: 1.5rem 0;
  background: #fff;
  box-shadow: 0 2px 10px rgba(27,63,110,.07);
  display: flex;
  flex-direction: column;
}

/* ── 画像エリア ── */
.aff-img-wrap {
  position: relative;
  background: var(--accent);
  height: 140px;
  overflow: hidden;
}
.aff-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.aff-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  background: linear-gradient(135deg, var(--accent) 0%, color-mix(in srgb, var(--accent) 70%, #fff) 100%);
}
.aff-brand-initial {
  font-size: 2.5rem;
  font-weight: 900;
  color: rgba(255,255,255,.25);
  line-height: 1;
}
.aff-brand-name-bg {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.05em;
}

/* バッジ */
.aff-badge {
  position: absolute;
  top: 0.6rem;
  left: 0.6rem;
  background: #c4703b;
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  letter-spacing: 0.03em;
}

/* ── 本文 ── */
.aff-body {
  padding: 1rem 1.2rem 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.aff-brand {
  font-size: 0.72rem;
  font-weight: 700;
  color: #8fa0b0;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 0;
}
.aff-catch {
  font-size: 0.95rem;
  font-weight: 700;
  color: #212b38;
  line-height: 1.5;
  margin: 0;
}
.aff-price {
  font-size: 0.82rem;
  color: #c4703b;
  font-weight: 700;
  margin: 0;
}
.aff-features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.aff-features li {
  font-size: 0.8rem;
  color: #536070;
  padding-left: 1rem;
  position: relative;
}
.aff-features li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #16a34a;
  font-size: 0.75rem;
}
.aff-btn {
  display: block;
  background: var(--accent);
  color: #fff;
  text-align: center;
  padding: 0.72rem 1rem;
  border-radius: 6px;
  font-size: 0.92rem;
  font-weight: 700;
  text-decoration: none;
  margin-top: 0.35rem;
  transition: opacity .15s, transform .15s;
}
.aff-btn:hover {
  opacity: .88;
  transform: translateY(-1px);
}
.aff-disc {
  font-size: 0.65rem;
  color: #8fa0b0;
  margin: 0;
  text-align: right;
}
</style>
