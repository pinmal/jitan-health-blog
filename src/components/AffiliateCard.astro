---
// アフィリエイトカード：A8.net / Amazon / 楽天（直接アフィリ）の3ASP対応
// href のみ → 単一ボタン（後方互換）
// amazonUrl / rakutenUrl を追加すると並列ボタン表示
// ── プロップ名エイリアス ──
//   brand / catchcopy  → 旧フォーマット（全64記事）
//   title / description → 新フォーマットエイリアス（brand/catchcopy に自動解決）
//   shopComment         → description 直下に表示するコメント文（新フォーマット専用）
interface Props {
  href?: string;          // A8.net リンク（または公式URL）
  brand?: string;
  catchcopy?: string;
  // 新フォーマット（title/description/shopComment）—— 旧フォーマットにフォールバック
  title?: string;
  description?: string;
  shopComment?: string;
  imageSrc?: string;
  imageAlt?: string;
  price?: string;
  features?: string[];
  badge?: string;
  platform?: string;      // 後方互換用（単一ボタン時の表示名）
  accentColor?: string;
  amazonUrl?: string;     // Amazon アソシエイト直接リンク
  rakutenUrl?: string;    // 楽天アフィリエイト直接リンク
  isAffiliate?: boolean;  // false = 公式サイト直リンク（アフィリ未提携）の場合に開示文を変更
}

const {
  href,
  brand,
  catchcopy,
  title,
  description,
  shopComment,
  imageSrc,
  imageAlt,
  price,
  features = [],
  badge,
  platform = 'A8.net',
  accentColor = '#1b3f6e',
  amazonUrl,
  rakutenUrl,
  isAffiliate = true,
} = Astro.props;

// 新旧フォーマット自動解決
const resolvedBrand    = brand    ?? title       ?? '';
const resolvedCatchcopy = catchcopy ?? description ?? '';

// 並列ボタンモードかどうか
const isMulti = !!(amazonUrl || rakutenUrl);

// 表示するプラットフォーム名を列挙（開示文用）
const platforms: string[] = [];
if (href) platforms.push(isMulti ? 'A8.net' : platform);
if (amazonUrl) platforms.push('Amazonアソシエイト');
if (rakutenUrl) platforms.push('楽天アフィリエイト');
const discText = platforms.join(' / ');
---

<div class="aff-wrap">
  {/* バナー（上部・独立） */}
  {imageSrc && (
    <a href={href ?? amazonUrl ?? rakutenUrl ?? '#'} class="aff-banner-link" target="_blank" rel="sponsored noopener noreferrer">
      <img src={imageSrc} alt={imageAlt ?? resolvedBrand} loading="lazy" class="aff-banner-img" />
    </a>
  )}

  {/* 説明カード */}
  <div class="aff-card" style={`--accent: ${accentColor}`}>
    {badge && <span class="aff-badge">{badge}</span>}
    <div class="aff-body">
      <p class="aff-brand">{resolvedBrand}</p>
      <p class="aff-catch">{resolvedCatchcopy}</p>
      {shopComment && <p class="aff-shop-comment">{shopComment}</p>}

      {price && <p class="aff-price">{price}</p>}

      {features.length > 0 && (
        <ul class="aff-features">
          {features.map(f => <li>{f}</li>)}
        </ul>
      )}

      {/* ── ボタン ── */}
      {isMulti ? (
        <div class="aff-btn-row">
          {href && (
            <a href={href} class="aff-btn aff-btn--a8 affiliate-link-btn" target="_blank" rel="sponsored noopener noreferrer" style={`--accent: ${accentColor}`} data-ga-brand={resolvedBrand} data-ga-platform="A8.net">
              最安値をチェック
            </a>
          )}
          {amazonUrl && (
            <a href={amazonUrl} class="aff-btn aff-btn--amazon affiliate-link-btn" target="_blank" rel="sponsored noopener noreferrer" data-ga-brand={resolvedBrand} data-ga-platform="Amazon">
              Amazonで見る
            </a>
          )}
          {rakutenUrl && (
            <a href={rakutenUrl} class="aff-btn aff-btn--rakuten affiliate-link-btn" target="_blank" rel="sponsored noopener noreferrer" data-ga-brand={resolvedBrand} data-ga-platform="楽天">
              楽天で見る
            </a>
          )}
        </div>
      ) : (
        href && (
          <a href={href} class="aff-btn aff-btn--single affiliate-link-btn" target="_blank" rel="sponsored noopener noreferrer" data-ga-brand={resolvedBrand} data-ga-platform={platform}>
            最安値をチェック →
          </a>
        )
      )}

      {isAffiliate
        ? <p class="aff-disc">※ アフィリエイト広告（{discText}）</p>
        : <p class="aff-disc">※ 公式サイトへの外部リンクです（アフィリエイト提携なし）</p>
      }
    </div>
  </div>
</div>

<style>
.aff-wrap {
  margin: 1.5rem 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

/* ── バナー ── */
.aff-banner-link {
  display: block;
  text-decoration: none;
  line-height: 0;
}
.aff-banner-img {
  max-width: 100%;
  height: auto;
  display: block;
}

/* ── カード ── */
.aff-card {
  border: 1px solid #e0dbd2;
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 10px rgba(27,63,110,.07);
  display: flex;
  flex-direction: column;
  width: 100%;
  position: relative;
}

/* バッジ */
.aff-badge {
  position: absolute;
  top: 0.6rem;
  right: 0.6rem;
  background: #c4703b;
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  letter-spacing: 0.03em;
}

/* ── 本文 ── */
.aff-body {
  padding: 1rem 1.2rem 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.aff-brand {
  font-size: 0.72rem;
  font-weight: 700;
  color: #8fa0b0;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 0;
}
.aff-catch {
  font-size: 0.95rem;
  font-weight: 700;
  color: #212b38;
  line-height: 1.5;
  margin: 0;
}
.aff-price {
  font-size: 0.82rem;
  color: #c4703b;
  font-weight: 700;
  margin: 0;
}
.aff-features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.aff-features li {
  font-size: 0.8rem;
  color: #536070;
  padding-left: 1rem;
  position: relative;
}
.aff-features li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #16a34a;
  font-size: 0.75rem;
}

/* ── 単一ボタン（後方互換） ── */
.aff-btn--single {
  display: block;
  background: #e67e22;
  color: #fff;
  text-align: center;
  padding: 0.72rem 1rem;
  border-radius: 6px;
  font-size: 0.92rem;
  font-weight: 700;
  text-decoration: none;
  margin-top: 0.35rem;
  transition: opacity .15s, transform .15s;
}
.aff-btn--single:hover {
  opacity: .88;
  transform: translateY(-1px);
}

/* ── 並列ボタン行 ── */
.aff-btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.35rem;
}
.aff-btn {
  flex: 1;
  min-width: 130px;
  text-align: center;
  padding: 0.65rem 0.8rem;
  border-radius: 6px;
  font-size: 0.84rem;
  font-weight: 700;
  text-decoration: none;
  color: #fff;
  transition: opacity .15s, transform .15s;
  white-space: nowrap;
}
.aff-btn:hover {
  opacity: .88;
  transform: translateY(-1px);
}

/* A8 ボタン: accentColor を使用 */
.aff-btn--a8 {
  background: var(--accent);
}

/* Amazon ボタン */
.aff-btn--amazon {
  background: linear-gradient(135deg, #ff9900, #e47911);
}

/* 楽天ボタン */
.aff-btn--rakuten {
  background: linear-gradient(135deg, #bf0000, #9a0000);
}

/* shopComment */
.aff-shop-comment {
  font-size: 0.8rem;
  color: #536070;
  line-height: 1.6;
  margin: 0;
  border-left: 2px solid var(--accent);
  padding-left: 0.6rem;
  font-style: italic;
}

/* 開示文 */
.aff-disc {
  font-size: 0.65rem;
  color: #8fa0b0;
  margin: 0;
  text-align: right;
}
</style>

<script>
(function () {
  // 同一script断片がKindleBookCard.astro等にも複製配置されているため、
  // 同一ページ内で複数回実行されても二重計上しないようdata属性でガードする
  document.querySelectorAll('.affiliate-link-btn').forEach(function (el) {
    if (el.dataset.gaTracked === '1') return;
    el.dataset.gaTracked = '1';
    el.addEventListener('click', function () {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'affiliate_click', {
          brand: el.dataset.gaBrand,
          platform: el.dataset.gaPlatform,
        });
      }
    });
  });
})();
</script>
