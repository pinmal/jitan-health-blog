---
interface Props {
  href: string;
  brand: string;
  catchcopy: string;
  imageSrc?: string;
  imageAlt?: string;
  price?: string;
  features?: string[];
  badge?: string;
  platform?: string;
  accentColor?: string;
}

const {
  href,
  brand,
  catchcopy,
  imageSrc,
  imageAlt,
  price,
  features = [],
  badge,
  platform = 'A8.net',
  accentColor = '#1b3f6e',
} = Astro.props;
---

<div class="aff-wrap">
  {/* バナー：説明ブロックの上・独立配置 */}
  {imageSrc && (
    <a href={href} class="aff-banner-link" target="_blank" rel="noopener noreferrer nofollow">
      <img src={imageSrc} alt={imageAlt ?? brand} loading="lazy" class="aff-banner-img" />
    </a>
  )}

  {/* 説明ブロック */}
  <div class="aff-card" style={`--accent: ${accentColor}`}>
    {badge && <span class="aff-badge">{badge}</span>}
    <div class="aff-body">
      <p class="aff-brand">{brand}</p>
      <p class="aff-catch">{catchcopy}</p>

      {price && <p class="aff-price">{price}</p>}

      {features.length > 0 && (
        <ul class="aff-features">
          {features.map(f => <li>{f}</li>)}
        </ul>
      )}

      <a href={href} class="aff-btn" target="_blank" rel="noopener noreferrer nofollow" style={`--accent: ${accentColor}`}>
        公式サイトをみる →
      </a>
      <p class="aff-disc">※ アフィリエイト広告（{platform}）</p>
    </div>
  </div>
</div>

<style>
.aff-wrap {
  margin: 1.5rem 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

/* ── バナー（上部・独立） ── */
.aff-banner-link {
  display: block;
  text-decoration: none;
  line-height: 0;
}
.aff-banner-img {
  max-width: 100%;
  height: auto;
  display: block;
}

/* ── 説明ブロック（カード） ── */
.aff-card {
  border: 1px solid #e0dbd2;
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 10px rgba(27,63,110,.07);
  display: flex;
  flex-direction: column;
  width: 100%;
  position: relative;
}

/* バッジ */
.aff-badge {
  position: absolute;
  top: 0.6rem;
  right: 0.6rem;
  background: #c4703b;
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  letter-spacing: 0.03em;
}

/* ── 本文 ── */
.aff-body {
  padding: 1rem 1.2rem 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.aff-brand {
  font-size: 0.72rem;
  font-weight: 700;
  color: #8fa0b0;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 0;
}
.aff-catch {
  font-size: 0.95rem;
  font-weight: 700;
  color: #212b38;
  line-height: 1.5;
  margin: 0;
}
.aff-price {
  font-size: 0.82rem;
  color: #c4703b;
  font-weight: 700;
  margin: 0;
}
.aff-features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.aff-features li {
  font-size: 0.8rem;
  color: #536070;
  padding-left: 1rem;
  position: relative;
}
.aff-features li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #16a34a;
  font-size: 0.75rem;
}
.aff-btn {
  display: block;
  background: var(--accent);
  color: #fff;
  text-align: center;
  padding: 0.72rem 1rem;
  border-radius: 6px;
  font-size: 0.92rem;
  font-weight: 700;
  text-decoration: none;
  margin-top: 0.35rem;
  transition: opacity .15s, transform .15s;
}
.aff-btn:hover {
  opacity: .88;
  transform: translateY(-1px);
}
.aff-disc {
  font-size: 0.65rem;
  color: #8fa0b0;
  margin: 0;
  text-align: right;
}
</style>
