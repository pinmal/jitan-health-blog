---
// 架空キャラクター（宮本ユウカ）の発言ブロック
// 読者の心の声・疑問・体験談を代弁する
interface Props {
  name?: string;
  note?: string;
}

const { name = 'ユウカ', note = '34歳・IT系・一人暮らし（架空のキャラクターです）' } = Astro.props;
---

<aside class="character-block">
  <div class="character-header">
    <span class="character-avatar">💬</span>
    <span class="character-name">{name}</span>
    <span class="character-note">{note}</span>
  </div>
  <div class="character-body">
    <slot />
  </div>
</aside>

<style>
.character-block {
  border-left: 3px solid #c4703b;
  background: #fdf6f1;
  border-radius: 0 8px 8px 0;
  padding: 0.85rem 1.1rem 0.85rem 1rem;
  margin: 1.5rem 0;
}
.character-header {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
  margin-bottom: 0.45rem;
}
.character-avatar {
  font-size: 0.9rem;
}
.character-name {
  font-size: 0.72rem;
  font-weight: 700;
  color: #c4703b;
  letter-spacing: 0.03em;
}
.character-note {
  font-size: 0.65rem;
  color: #9c7a6a;
  font-style: italic;
}
.character-body {
  font-size: 0.92rem;
  line-height: 1.85;
  color: #3d2b1f;
}
.character-body :global(p) { margin: 0 0 0.65rem; }
.character-body :global(p:last-child) { margin-bottom: 0; }
</style>
