---
import { getCollection } from 'astro:content';
import { generateArticleSchema, type FaqItem } from '../utils/schema';
import RelatedArticles from '../components/RelatedArticles.astro';
import SiteInfoCard from '../components/SiteInfoCard.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  categoryLabel: string;
  publishedAt: Date;
  updatedAt?: Date;
  noindex?: boolean;
  humanReviewed?: boolean;
  faqs?: FaqItem[];
}

const {
  title,
  description,
  category,
  categoryLabel,
  publishedAt,
  updatedAt,
  noindex = false,
  humanReviewed = false,
  faqs,
} = Astro.props;

const url = Astro.url.href;
// 記事スラッグを抽出（例: /articles/noshi-vs-mitsuboshi → noshi-vs-mitsuboshi）
const slug = Astro.url.pathname.replace(/^\/articles\//, '').replace(/\/$/, '') || 'article';

const articleSchema = generateArticleSchema({ title, description, url, publishedAt, updatedAt, category, categoryLabel, faqs });

// 関連記事を複数グループで取得（2026-05-28: タグ重複優先 + 比較記事プロモーション対応）
const allArticles = await getCollection('articles');
const validArticles = allArticles.filter(a =>
  a.data.humanReviewed === true &&
  a.slug !== slug &&
  !a.id.startsWith('_')
);

// 現在の記事のキャラ・タグを取得
const currentArticle = allArticles.find(a => a.slug === slug);
const currentChar = currentArticle?.data.character;
const currentTags = currentArticle?.data.tags ?? [];

// グループ1: タグ重複≥1の関連記事（テーマ近接順）最大3件
// 旧: 同カテゴリ最新3件（同カテゴリ68本が全員同じ3本にリンクしてしまう問題を修正）
const tagRelevantArticles = currentTags.length > 0
  ? validArticles
      .map(a => ({
        article: a,
        overlap: (a.data.tags ?? []).filter(t => currentTags.includes(t)).length,
      }))
      .filter(({ overlap }) => overlap >= 1)
      .sort((a, b) =>
        b.overlap - a.overlap ||
        new Date(b.article.data.publishedAt).valueOf() - new Date(a.article.data.publishedAt).valueOf()
      )
      .slice(0, 3)
      .map(({ article }) => ({
        href: `/articles/${article.slug}/`,
        title: article.data.title,
        label: '関連記事',
      }))
  : [];

const tagRelevantIds = new Set(tagRelevantArticles.map(a => a.href));

// グループ2: 比較記事プロモーション（review/health-column/howto/mental-health 閲覧時のみ）
// 比較記事はコンバージョン率最高・review記事から必ず誘導する
const comparisonPromoArticles = category !== 'comparison'
  ? validArticles
      .filter(a =>
        a.data.category === 'comparison' &&
        !tagRelevantIds.has(`/articles/${a.slug}/`)
      )
      .sort((a, b) => {
        // タグ重複があれば優先
        const overlapA = (a.data.tags ?? []).filter(t => currentTags.includes(t)).length;
        const overlapB = (b.data.tags ?? []).filter(t => currentTags.includes(t)).length;
        return overlapB - overlapA ||
          new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf();
      })
      .slice(0, 3)
      .map(a => ({
        href: `/articles/${a.slug}/`,
        title: a.data.title,
        label: '比較',
      }))
  : [];

const allUsedIds = new Set([
  ...tagRelevantIds,
  ...comparisonPromoArticles.map(a => a.href),
]);

// グループ3: 同じキャラの他記事（既出除外）最大3件
const sameCharArticles = currentChar
  ? validArticles
      .filter(a =>
        a.data.character === currentChar &&
        !allUsedIds.has(`/articles/${a.slug}/`)
      )
      .sort((a, b) => new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf())
      .slice(0, 3)
      .map(a => ({
        href: `/articles/${a.slug}/`,
        title: a.data.title,
        label: '同じキャラ',
      }))
  : [];

const charLabels: Record<string, string> = {
  yuka: '宮本ユウカ',
  naoko: '田中ナオコ',
  kenji: '井上ケンジ',
};

const charColors: Record<string, string> = {
  yuka: '#c4703b',
  naoko: '#2d8b72',
  kenji: '#3b5f8b',
};

// ── キャラクター記事のストーリーナビ ──
interface StoryNav {
  episodeNum: number;
  totalEpisodes: number;
  prevSlug: string | null;
  prevTitle: string | null;
  nextSlug: string | null;
  nextTitle: string | null;
}
let storyNav: StoryNav | null = null;

if (currentChar) {
  const charArticlesAll = allArticles
    .filter(a =>
      a.data.character === currentChar &&
      a.data.humanReviewed === true &&
      !a.id.startsWith('_')
    )
    .sort((a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf());

  const currentIdx = charArticlesAll.findIndex(a => a.slug === slug);
  if (currentIdx !== -1) {
    const prev = currentIdx > 0 ? charArticlesAll[currentIdx - 1] : null;
    const next = currentIdx < charArticlesAll.length - 1 ? charArticlesAll[currentIdx + 1] : null;
    storyNav = {
      episodeNum: currentIdx + 1,
      totalEpisodes: charArticlesAll.length,
      prevSlug: prev ? `/articles/${prev.slug}/` : null,
      prevTitle: prev ? prev.data.title : null,
      nextSlug: next ? `/articles/${next.slug}/` : null,
      nextTitle: next ? next.data.title : null,
    };
  }
}

const relatedGroups = [
  ...(tagRelevantArticles.length > 0 ? [{
    heading: '同じテーマの記事',
    articles: tagRelevantArticles,
  }] : []),
  ...(comparisonPromoArticles.length > 0 ? [{
    heading: '比較記事も読む',
    articles: comparisonPromoArticles,
  }] : []),
  ...(sameCharArticles.length > 0 ? [{
    heading: `${currentChar ? charLabels[currentChar] : ''}の他のレビュー`,
    articles: sameCharArticles,
  }] : []),
].filter(g => g.articles.length > 0);

// カテゴリナビ用
const categoryNav = [
  { slug: 'comparison',     label: '比較',       icon: '📊' },
  { slug: 'review',         label: 'レビュー',   icon: '🍱' },
  { slug: 'health-column',  label: '健康コラム', icon: '🥗' },
  { slug: 'howto',          label: '仕組み化',   icon: '⚙️' },
  { slug: 'mental-health',  label: 'メンタル',   icon: '🧠' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P6YC8SXBSH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-P6YC8SXBSH');
    </script>
    {/* Google AdSense — 公開済み（humanReviewed）ページのみ配信。下書き・noindex記事には広告を出さない */}
    {humanReviewed && (
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9842738692752047"
         crossorigin="anonymous"></script>
    )}
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 時短 × 健康</title>
    <meta name="description" content={description} />
    {(noindex || !humanReviewed) && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={url} />
    <script type="application/ld+json" set:html={articleSchema} />
    <meta property="og:title" content={`${title} | 時短 × 健康`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content="https://jitan-kenko.blog/og-default.png" />
    <meta property="og:site_name" content="時短 × 健康" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://jitan-kenko.blog/og-default.png" />
  </head>

  <body data-article-slug={slug} data-article-title={title}>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand">
          <span class="brand-name">時短 × 健康</span>
          <span class="brand-sub">ー忙しい大人のための合理的食生活ー</span>
        </a>
        <nav class="header-cat-nav" aria-label="カテゴリ">
          {categoryNav.map(c => (
            <a
              href={`/${c.slug}/`}
              class={`header-cat-link${c.slug === category ? ' active' : ''}`}
              aria-current={c.slug === category ? 'page' : undefined}
            >
              <span class="header-cat-icon">{c.icon}</span>
              <span class="header-cat-label">{c.label}</span>
            </a>
          ))}
          <a href="/articles/" class="header-cat-link header-cat-link--all">
            <span class="header-cat-icon">📋</span>
            <span class="header-cat-label">全記事</span>
          </a>
          <a href="/kindle-guide/" class="header-cat-link header-cat-link--kindle">
            <span class="header-cat-icon">📚</span>
            <span class="header-cat-label">Kindle本</span>
          </a>
        </nav>
      </div>
    </header>

    <main class="article-main">
      <div class="article-container">
        {!humanReviewed && (
          <div class="draft-banner" role="alert">
            ⚠️ この記事は編集確認中です（noindex中）
          </div>
        )}

        <nav class="breadcrumb" aria-label="パンくずリスト">
          <ol>
            <li><a href="/">トップ</a></li>
            <li><a href={`/${category}/`}>{categoryLabel}</a></li>
            <li aria-current="page">{title}</li>
          </ol>
        </nav>

        <article>
          <h1 class="article-title">{title}</h1>
          <p class="article-meta">
            <time class="article-date" datetime={publishedAt.toISOString()}>
              {updatedAt
                ? `更新: ${updatedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}`
                : `公開: ${publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}`}
            </time>
          </p>

          {storyNav && currentChar && (
            <div class="story-indicator" style={`--char-color:${charColors[currentChar]}`}>
              <a href={`/character/${currentChar}/`} class="story-indicator-link">
                <span class="story-indicator-char">{charLabels[currentChar]}のストーリー</span>
                <strong class="story-indicator-ep">第{storyNav.episodeNum}話 / 全{storyNav.totalEpisodes}話</strong>
              </a>
              {storyNav.episodeNum > 1 && (
                <a href={`/character/${currentChar}/`} class="story-indicator-start">↩ 第1話から読む</a>
              )}
            </div>
          )}

          {currentChar && (
            <div class="fiction-disclosure" role="note" aria-label="記事形式の説明">
              <span class="fiction-disclosure-icon">📌</span>
              <div class="fiction-disclosure-text">
                <strong>この記事について：</strong>
                登場する「{charLabels[currentChar]}」は架空のキャラクターです。体験談部分はフィクションですが、製品の価格・仕様・効果に関する情報は公式サイトおよび複数の利用者レビューをもとに作成しています。アフィリエイトリンクを含みます（<a href="/disclaimer" class="fiction-disclosure-link">免責事項</a>）。
              </div>
            </div>
          )}

          <slot />

          {storyNav && currentChar && (
            <nav class="story-nav" aria-label="ストーリーナビゲーション" style={`--char-color:${charColors[currentChar]}`}>
              <div class="story-nav-header">
                <a href={`/character/${currentChar}/`} class="story-nav-series">
                  {charLabels[currentChar]}のストーリー一覧
                </a>
                <span class="story-nav-pos">第{storyNav.episodeNum}話 / 全{storyNav.totalEpisodes}話</span>
              </div>
              <div class="story-nav-arrows">
                {storyNav.prevSlug ? (
                  <a href={storyNav.prevSlug} class="story-nav-btn story-nav-prev">
                    <span>← 前の話</span>
                    <span class="story-nav-title">{storyNav.prevTitle}</span>
                  </a>
                ) : (
                  <span class="story-nav-btn story-nav-disabled">← 最初の話</span>
                )}
                <a href={`/character/${currentChar}/`} class="story-nav-center-btn">一覧へ</a>
                {storyNav.nextSlug ? (
                  <a href={storyNav.nextSlug} class="story-nav-btn story-nav-next">
                    <span>次の話 →</span>
                    <span class="story-nav-title">{storyNav.nextTitle}</span>
                  </a>
                ) : (
                  <span class="story-nav-btn story-nav-disabled">最新話 →</span>
                )}
              </div>
            </nav>
          )}

          <SiteInfoCard />

          {/* 関連記事（同カテゴリ + 同キャラ + タグ重複の3グループ） */}
          {relatedGroups.length > 0 && (
            <RelatedArticles groups={relatedGroups} />
          )}

          {/* カテゴリ全体へのナビ */}
          <nav class="cat-explore" aria-label="他のカテゴリを探す">
            <h2 class="cat-explore-heading">他のカテゴリも見る</h2>
            <div class="cat-explore-chips">
              {categoryNav.filter(c => c.slug !== category).map(c => (
                <a href={`/${c.slug}/`} class="cat-explore-chip">
                  <span>{c.icon}</span>
                  <span>{c.label}</span>
                </a>
              ))}
              <a href="/articles/" class="cat-explore-chip cat-explore-chip--all">
                <span>📋</span>
                <span>全記事一覧</span>
              </a>
              <a href="/kindle-guide/" class="cat-explore-chip cat-explore-chip--kindle">
                <span>📚</span>
                <span>Kindle本ガイド</span>
              </a>
            </div>
          </nav>

          {/* ページトップリンク */}
          <div class="back-to-top-wrap">
            <a href="#top" class="back-to-top-link" id="back-to-top-inline">
              ↑ この記事のトップへ戻る
            </a>
          </div>
        </article>
      </div>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>&copy; 2026 時短 × 健康</p>
        <nav>
          <a href="/kindle-guide/">Kindle本ガイド</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/about">このブログについて</a>
          <a href="https://drnagatomo2026.com" target="_blank" rel="noopener">監修医の医療ブログ</a>
          <a href="https://donoka.jp" target="_blank" rel="noopener">何科に行けばいい？ donoka.jp</a>
        </nav>
        <p class="affiliate-disclaimer">当サイトはA8.net等のアフィリエイトプログラムに参加しています。</p>
      </div>
    </footer>

    <!-- ===== フローティング「トップへ戻る」ボタン ===== -->
    <button id="scroll-top-btn" aria-label="ページトップへ戻る" title="ページトップへ戻る">↑</button>

    <!-- ===== 医師用インライン編集ツールバー（通常は完全非表示・URLパラメータ ?edit=1 で表示） ===== -->
    <div id="editor-toolbar" aria-label="編集ツールバー" hidden>
      <button id="edit-toggle" aria-pressed="false">✏️ 編集モード</button>
      <button id="review-btn" hidden>📋 Claude確認依頼</button>
      <span id="edit-status"></span>
    </div>

    <!-- 確認依頼モーダル -->
    <div id="review-modal" hidden role="dialog" aria-modal="true" aria-label="Claude確認依頼">
      <div id="review-modal-inner">
        <h2 id="review-modal-title">Claude確認依頼プロンプト</h2>
        <p id="review-modal-hint">以下をコピーしてClaudeに貼り付けてください</p>
        <textarea id="review-prompt-text" readonly></textarea>
        <div id="review-modal-btns">
          <button id="copy-prompt-btn">📋 コピー</button>
          <button id="close-modal-btn">閉じる</button>
        </div>
      </div>
    </div>
  <!-- affiliate_click auto-tracker -->
  <script is:inline>
  (function(){document.addEventListener('click',function(e){var a=e.target.closest('a');if(!a)return;var h=a.href||'';var s=null;if(h.indexOf('amazon.co.jp')!==-1)s='amazon';else if(h.indexOf('afl.rakuten.co.jp')!==-1||h.indexOf('search.rakuten.co.jp')!==-1)s='rakuten';else if(h.indexOf('naturum.co.jp')!==-1)s='naturum';else if(h.indexOf('af.moshimo.com')!==-1)s='moshimo';else if(h.indexOf('px.a8.net')!==-1){try{var ar=new URL(h).searchParams.get('a8ejpredirect');s=ar&&new URL(decodeURIComponent(ar)).hostname.indexOf('naturum.co.jp')!==-1?'naturum':'a8';}catch(e2){s='a8';}}if(!s)return;var l='unknown';try{var u=new URL(h);var k=u.searchParams.get('k')||u.searchParams.get('keyword');if(k){l=decodeURIComponent(k).slice(0,60);}else{var m=u.pathname.match(/\/dp\/([A-Z0-9]{10})/);if(m)l='ASIN:'+m[1];var r=u.searchParams.get('a8ejpredirect');if(r){try{var i=new URL(decodeURIComponent(r));var nk=i.searchParams.get('keyword')||i.searchParams.get('k');if(nk)l=decodeURIComponent(nk).slice(0,60);}catch(e2){}}var pc=u.searchParams.get('pc');if(pc){try{var iu=new URL(decodeURIComponent(pc));var sg=iu.pathname.split('/').filter(Boolean);var ix=sg.indexOf('mall');if(ix>=0&&sg[ix+1])l=decodeURIComponent(sg[ix+1]).slice(0,60);}catch(e2){}}}}catch(e){}if(typeof window.gtag==='function')window.gtag('event','affiliate_click',{store:s,item_label:l,page_path:window.location.pathname});},{passive:true});})();
  </script>
  </body>
</html>

<!-- フローティング「トップへ戻る」スクロール制御 -->
<script is:inline>
(function () {
  var btn = document.getElementById('scroll-top-btn');
  if (!btn) return;
  window.addEventListener('scroll', function () {
    if (window.scrollY > 400) {
      btn.classList.add('visible');
    } else {
      btn.classList.remove('visible');
    }
  }, { passive: true });
  btn.addEventListener('click', function () {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>

<!-- インライン編集システム（クライアントサイド） -->
<script is:inline>
(function () {
  const body       = document.body;
  const slug       = body.dataset.articleSlug  || 'article';
  const artTitle   = body.dataset.articleTitle || '記事';
  const STORE_KEY  = 'jitan-edit:' + slug;

  // ===== ストレージ操作 =====
  function loadEdits() {
    try { return JSON.parse(localStorage.getItem(STORE_KEY) || '{}'); } catch { return {}; }
  }
  function saveEdits(data) {
    localStorage.setItem(STORE_KEY, JSON.stringify(data));
  }

  // ===== 起動時: ローカルストレージの編集内容を画面に反映 =====
  function applyStoredEdits() {
    const edits = loadEdits();
    document.querySelectorAll('[data-dc-block]').forEach(function (block, idx) {
      const id = block.dataset.dcBlock + ':' + idx;
      if (!edits[id]) return;
      const bodyEl = block.querySelector('[data-dc-content]');
      if (bodyEl) bodyEl.innerHTML = '<p>' + edits[id].text.replace(/\n\n/g, '</p><p>') + '</p>';
      const headingEl = block.querySelector('[data-dc-heading]');
      if (headingEl && edits[id].label) headingEl.textContent = edits[id].label;
      block.setAttribute('data-dc-edited', 'true');
    });
  }
  applyStoredEdits();

  // ===== ツールバー要素 =====
  const toolbar   = document.getElementById('editor-toolbar');
  const toggleBtn = document.getElementById('edit-toggle');
  const reviewBtn = document.getElementById('review-btn');
  const statusEl  = document.getElementById('edit-status');
  const modal     = document.getElementById('review-modal');
  const promptTA  = document.getElementById('review-prompt-text');
  const copyBtn   = document.getElementById('copy-prompt-btn');
  const closeBtn  = document.getElementById('close-modal-btn');

  // URLパラメータ ?edit=1 がある場合のみツールバーを表示（医師専用）
  var urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('edit') === '1') {
    toolbar.hidden = false;
  }

  // 保存済み編集があれば確認依頼ボタンを表示
  if (Object.keys(loadEdits()).length > 0) reviewBtn.hidden = false;

  let editMode = false;

  // ===== 編集モード切替 =====
  toggleBtn.addEventListener('click', function () {
    editMode = !editMode;
    toggleBtn.setAttribute('aria-pressed', String(editMode));
    toggleBtn.textContent = editMode ? '✅ 編集モード終了' : '✏️ 編集モード';
    statusEl.textContent  = editMode ? '各ブロックの「✏️ 編集」ボタンを押して編集できます' : '';

    document.querySelectorAll('[data-dc-edit]').forEach(function (btn) {
      btn.hidden = !editMode;
    });
  });

  // ===== 各ブロックの編集ボタン =====
  document.querySelectorAll('[data-dc-block]').forEach(function (block, idx) {
    const editBtn  = block.querySelector('[data-dc-edit]');
    const bodyEl   = block.querySelector('[data-dc-content]');
    const headingEl= block.querySelector('[data-dc-heading]');
    if (!editBtn || !bodyEl) return;

    const id = block.dataset.dcBlock + ':' + idx;

    editBtn.addEventListener('click', function () {
      if (block.classList.contains('dc-editing')) return;
      block.classList.add('dc-editing');

      // 現在のテキストを取得（段落を改行に変換）
      const currentText = Array.from(bodyEl.querySelectorAll('p'))
        .map(function (p) { return p.textContent.trim(); })
        .join('\n\n') || bodyEl.textContent.trim();

      const currentLabel = headingEl ? headingEl.textContent : '';

      // テキストエリアを生成
      const ta = document.createElement('textarea');
      ta.className = 'dc-textarea';
      ta.value = currentText;
      ta.placeholder = 'ここにコメントを入力してください...';

      // 見出し編集フィールド
      const labelRow = document.createElement('div');
      labelRow.style.cssText = 'padding:.5rem 1rem;background:#f8fafc;border-top:1px solid #e2e8f0;display:flex;align-items:center;gap:.5rem;';
      const labelInput = document.createElement('input');
      labelInput.type = 'text';
      labelInput.value = currentLabel;
      labelInput.placeholder = '見出し（例: 患者さんに実際に勧めた結果）';
      labelInput.style.cssText = 'flex:1;padding:.3rem .6rem;font-size:.83rem;border:1px solid #cbd5e1;border-radius:4px;';
      const labelText = document.createElement('span');
      labelText.textContent = '見出し:';
      labelText.style.cssText = 'font-size:.78rem;color:#64748b;white-space:nowrap;';
      labelRow.appendChild(labelText);
      labelRow.appendChild(labelInput);

      // 保存バー
      const saveBar   = document.createElement('div');
      saveBar.className = 'dc-save-bar';
      const saveBtn   = document.createElement('button');
      saveBtn.className = 'dc-save-btn';
      saveBtn.textContent = '💾 保存';
      const cancelBtn = document.createElement('button');
      cancelBtn.className = 'dc-cancel-btn';
      cancelBtn.textContent = 'キャンセル';
      const savedBadge= document.createElement('span');
      savedBadge.className = 'dc-saved-badge';
      savedBadge.textContent = '✅ 保存しました';
      saveBar.appendChild(saveBtn);
      saveBar.appendChild(cancelBtn);
      saveBar.appendChild(savedBadge);

      // 既存コンテンツを非表示にしてテキストエリアを挿入
      bodyEl.style.display = 'none';
      bodyEl.after(ta);
      ta.after(labelRow);
      labelRow.after(saveBar);
      ta.focus();

      // 保存処理
      saveBtn.addEventListener('click', function () {
        const newText  = ta.value.trim();
        const newLabel = labelInput.value.trim();
        if (!newText) return;

        // DOM更新
        bodyEl.innerHTML = '<p>' + newText.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>') + '</p>';
        if (headingEl && newLabel) headingEl.textContent = newLabel;
        block.setAttribute('data-dc-edited', 'true');

        // ローカルストレージ保存
        const edits = loadEdits();
        edits[id] = { text: newText, label: newLabel, savedAt: new Date().toISOString() };
        saveEdits(edits);

        // UI復元
        bodyEl.style.display = '';
        ta.remove();
        labelRow.remove();
        saveBar.remove();
        block.classList.remove('dc-editing');

        savedBadge.style.display = 'inline';
        setTimeout(function () { savedBadge.style.display = 'none'; }, 2000);

        reviewBtn.hidden = false;
        statusEl.textContent = '保存完了 ✅';
        setTimeout(function () { statusEl.textContent = editMode ? '各ブロックの「✏️ 編集」ボタンを押して編集できます' : ''; }, 2000);
      });

      // キャンセル処理
      cancelBtn.addEventListener('click', function () {
        bodyEl.style.display = '';
        ta.remove();
        labelRow.remove();
        saveBar.remove();
        block.classList.remove('dc-editing');
      });
    });
  });

  // ===== Claude確認依頼プロンプト生成 =====
  reviewBtn.addEventListener('click', function () {
    const edits = loadEdits();
    if (Object.keys(edits).length === 0) {
      alert('まだ保存した編集がありません。');
      return;
    }

    const blocks = document.querySelectorAll('[data-dc-block]');
    let changedLines = '';
    blocks.forEach(function (block, idx) {
      const id = block.dataset.dcBlock + ':' + idx;
      if (!edits[id]) return;
      const type  = block.dataset.dcType  || 'unknown';
      const label = edits[id].label || block.dataset.dcLabel || '';
      changedLines += '\n【' + type + '】' + label + '\n';
      changedLines += '---\n' + edits[id].text + '\n---\n';
    });

    const prompt =
      '以下の記事編集内容を確認してください。\n\n' +
      '📄 記事ファイル: src/content/articles/' + slug + '.mdx\n' +
      '📝 記事タイトル: ' + artTitle + '\n\n' +
      '=== 変更したDoctorCommentブロック ===\n' +
      changedLines + '\n' +
      '=== 確認依頼事項 ===\n' +
      '1. 薬機法・医療広告ガイドラインのNGワードチェック\n' +
      '2. 医学的に不適切な表現がないかの確認\n' +
      '3. 上記テキストでMDXファイルを更新してください\n' +
      '4. 問題なければ humanReviewed: true に変更してください\n\n' +
      '（編集日時: ' + new Date().toLocaleString('ja-JP') + '）';

    promptTA.value = prompt;
    modal.hidden = false;
  });

  // コピー
  copyBtn.addEventListener('click', function () {
    promptTA.select();
    document.execCommand('copy');
    copyBtn.textContent = '✅ コピーしました';
    setTimeout(function () { copyBtn.textContent = '📋 コピー'; }, 2000);
  });

  // モーダルを閉じる
  closeBtn.addEventListener('click', function () { modal.hidden = true; });
  modal.addEventListener('click', function (e) { if (e.target === modal) modal.hidden = true; });
})();
</script>

