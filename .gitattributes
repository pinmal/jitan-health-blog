# Enforce LF line endings for all text files (prevent CRLF on Windows)
* text=auto eol=lf

# MDX/MD files: always LF, no BOM
*.mdx text eol=lf
*.md  text eol=lf

# Config files: LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.astro text eol=lf
*.css  text eol=lf

# Binaries: no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
